#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>
#include <string.h>
#include <math.h>

#define MAX 1000

// Stack for numbers
long long values[MAX];
int vtop = -1;

// Stack for operators
char ops[MAX];
int otop = -1;

// Push value
void pushValue(long long val) {
    values[++vtop] = val;
}

// Pop value
long long popValue() {
    return values[vtop--];
}

// Push operator
void pushOp(char op) {
    ops[++otop] = op;
}

// Pop operator
char popOp() {
    return ops[otop--];
}

// Check precedence
int precedence(char op) {
    if (op == '^')
        return 3;
    if (op == '*' || op == '/')
        return 2;
    if (op == '+' || op == '-')
        return 1;
    return 0;
}

// Apply operation
long long applyOp(long long a, long long b, char op) {
    switch(op) {
        case '+': return a + b;
        case '-': return a - b;
        case '*': return a * b;
        case '/': return a / b;
        case '^': return (long long)pow(a, b);
    }
    return 0;
}

int main() {
    char s[101];
    scanf("%s", s);

    int n = strlen(s);

    for (int i = 0; i < n; i++) {

        // If digit, parse full number
        if (isdigit(s[i])) {
            long long val = 0;

            while (i < n && isdigit(s[i])) {
                val = val * 10 + (s[i] - '0');
                i++;
            }

            pushValue(val);
            i--;
        }

        // Opening bracket
        else if (s[i] == '(') {
            pushOp(s[i]);
        }

        // Closing bracket
        else if (s[i] == ')') {

            while (otop != -1 && ops[otop] != '(') {
                long long b = popValue();
                long long a = popValue();
                char op = popOp();

                pushValue(applyOp(a, b, op));
            }

            popOp(); // remove '('
        }

        // Operator
        else {
            while (otop != -1 &&
                   precedence(ops[otop]) >= precedence(s[i])) {

                long long b = popValue();
                long long a = popValue();
                char op = popOp();

                pushValue(applyOp(a, b, op));
            }

            pushOp(s[i]);
        }
    }

    // Remaining operations
    while (otop != -1) {
        long long b = popValue();
        long long a = popValue();
        char op = popOp();

        pushValue(applyOp(a, b, op));
    }

    printf("%lld\n", popValue());

    return 0;
}
